# ============================================================
# feedgrab 配置文件模板
# 复制为 .env 后按需修改：cp .env.example .env
# ============================================================

# === 日志级别 ===
# FEEDGRAB_LOG_LEVEL=INFO              # 默认 INFO，可选 DEBUG/WARNING/ERROR

# === 输出配置 ===
OUTPUT_DIR=./output                    # Markdown 输出根目录
# OBSIDIAN_VAULT=                      # Obsidian 笔记库路径，设置后内容直接写入库中（优先级高于 OUTPUT_DIR）

# === 认证数据目录 ===
# Cookie/Session 统一存放目录，相对路径基于项目根目录，也支持绝对路径
# FEEDGRAB_DATA_DIR=sessions           # 默认 sessions

# === 浏览器 User-Agent ===
# 所有浏览器交互和 HTTP 请求统一使用此 UA，确保登录和抓取一致
# 推荐用自动检测：feedgrab detect-ua  → 读取本机真实 Chrome UA 并写入此处
# BROWSER_USER_AGENT=                  # 留空则使用内置默认值（Windows + Chrome 132）

# === Chrome CDP 自动提取 Cookie（可选，替代 feedgrab login）===
# Chrome 146+ 支持在 chrome://inspect/#remote-debugging 一键开启 Remote Debugging
# 开启后 feedgrab login <platform> 自动从运行中的 Chrome 提取 Cookie，无需手动登录
# 前提：Chrome 已打开并登录目标平台的页面
# CHROME_CDP_LOGIN=false               # true=CDP 自动提取，false=传统浏览器登录（默认）
# CHROME_CDP_PORT=9222                 # CDP 端口，默认 9222

# === Twitter/X Cookie 配置（任选其一）===
# 方式 1：feedgrab login twitter       → 浏览器登录，自动保存 session（推荐）
# 方式 2：在下方填写 Cookie 值          → 从浏览器 DevTools 复制，优先级最高
# 方式 3：手动创建 sessions/x.json     → 格式 {"auth_token": "xxx", "ct0": "xxx"}
# 方式 4：Chrome CDP 自动提取           → 需启动 Chrome --remote-debugging-port=9222
# X_AUTH_TOKEN=                        # Twitter auth_token Cookie
# X_CT0=                               # Twitter ct0 (CSRF) Cookie
#
# === 多账号 Cookie 轮换（防 429 限流）===
# 批量抓取时 GraphQL 容易触发 429 限流，配置多个账号可自动轮换：
#   sessions/twitter.json  ← 主账号（feedgrab login twitter 自动生成）
#   sessions/x_2.json      ← 第二个账号（手动填写，见下方教程）
#   sessions/x_3.json      ← 第三个账号...
# 格式统一为 {"auth_token": "xxx", "ct0": "xxx"}
# 429 时自动切换下一个账号，15 分钟冷却后自动恢复
#
# 🔑 手动获取 Cookie 方法（F12 DevTools）：
#   1. 用 Chrome/Edge 打开 https://x.com 并登录目标账号
#   2. 按 F12 打开开发者工具 → 切换到「Application」(应用) 标签
#   3. 左侧树展开 Cookies → 点击 https://x.com
#   4. 在右侧表格中找到并复制这两个值：
#      - auth_token: 一串十六进制字符（如 a9f00defce47...）
#      - ct0:        一串较长的字母数字（如 8b3f2a1e5c...）
#   5. 粘贴到 sessions/x_2.json 中对应字段即可
# 提示：Cookie 不绑定 IP/设备，可跨电脑使用（在 A 电脑获取，在 B 服务器运行）
#       只要不在浏览器上退出登录，Cookie 就一直有效

# === Twitter/X GraphQL 控制 ===
X_GRAPHQL_ENABLED=true                 # 是否启用 GraphQL 深度抓取，true 开启 / false 降级为 oEmbed+Jina
X_THREAD_MAX_PAGES=20                  # 线程分页最大页数，默认 20（每页约 20 条）
X_REQUEST_DELAY=1.5                    # GraphQL 请求间隔秒数，防止频率限制

# === Twitter/X 评论采集 ===
X_FETCH_AUTHOR_REPLIES=false           # 是否采集作者回帖（回复评论者），true 开启 / false 关闭
X_FETCH_ALL_COMMENTS=false             # 是否采集全部评论，true 开启 / false 关闭
# X_MAX_COMMENTS=50                    # 最大评论采集数，默认 50

# === Twitter/X 书签批量抓取 ===
X_BOOKMARKS_ENABLED=false              # 是否开启书签批量采集，true 开启 / false 关闭
# X_BOOKMARK_MAX_PAGES=50             # 书签分页最大页数，默认 50
# X_BOOKMARK_DELAY=2                  # 书签推文处理间隔秒数，默认 2

# === Twitter/X 按账号批量抓取 ===
X_USER_TWEETS_ENABLED=false            # 是否开启按推特账号批量采集，true 开启 / false 关闭
# X_USER_TWEET_MAX_PAGES=200          # 账号推文分页最大页数，默认 200（每页约 40 条）
# X_USER_TWEET_DELAY=2                # 账号推文处理间隔秒数，默认 2
# X_USER_TWEETS_SINCE=                # 仅抓取该日期之后的推文，格式 YYYY-MM-DD（如 2025-10-01），留空=全部

# === Twitter/X Search API 搜索补充（突破 UserTweets ~800 条限制）===
# X_SEARCH_SUPPLEMENTARY=true         # 搜索补充开关，UserTweets 抓不够时自动按月搜索补充（默认 true）
# X_SEARCH_MAX_PAGES_PER_CHUNK=50    # 每个月度搜索分片最大分页数，默认 50

# === Twitter/X 关键词搜索 (x-so) ===
X_SEARCH_ENABLED=true                     # 是否开启关键词搜索，true 开启 / false 关闭
# X_SEARCH_LANG=zh                       # 搜索语言，默认 zh（留空=不限语言）
# X_SEARCH_DAYS=1                        # 默认搜索天数，默认 1（最近24小时）
# X_SEARCH_MIN_FAVES=0                   # 默认最低点赞数，默认 0=不过滤
# X_SEARCH_MIN_RETWEETS=0                # 默认最低转发数，默认 0=不过滤
# X_SEARCH_SORT=live                     # 排序模式：live=最新, top=热门，默认 live
# X_SEARCH_EXCLUDE_RETWEETS=true         # 排除转推，默认 true
# X_SEARCH_DELAY=2.0                     # 滚动间隔秒数，默认 2.0
# X_SEARCH_MAX_RESULTS=100               # 每次搜索最大推文数，默认 100
# X_SEARCH_SAVE_TWEETS=false             # 是否保存单条推文 .md，默认 false（仅汇总表）
# X_SEARCH_MERGE_KEYWORDS=false          # 多关键词搜索时合并为一个汇总表（默认 false=各自独立文件）
# X_SEARCH_BROWSER_FALLBACK=true         # GraphQL 失败时自动降级浏览器搜索（CDP→Playwright，默认 true）
# 用法：feedgrab x-so openclaw
#       feedgrab x-so openclaw --days 3 --lang en --min-faves 100
#       feedgrab x-so 'openclaw lang:zh since:2026-03-06' --raw
#       feedgrab x-so "openclaw,ChatGPT,DeepSeek"               # 多关键词依次搜索
#       feedgrab x-so "openclaw,ChatGPT,DeepSeek" --merge       # 多关键词合并为一个汇总表
# 输出目录：{OUTPUT_DIR}/X/search/{days}day_{sort}/

# === Twitter/X 按列表批量抓取 ===
X_LIST_TWEETS_ENABLED=false            # 是否开启按 Twitter List 批量采集，true 开启 / false 关闭
# X_LIST_TWEETS_DAYS=1                # 抓取最近 N 天的推文，默认 1（=最近24小时），支持 1/2/3/7
# X_LIST_TWEET_MAX_PAGES=50          # 列表推文分页最大页数，默认 50
# X_LIST_TWEET_DELAY=2                 # 列表推文处理间隔秒数，默认 2
# 用法：X_LIST_TWEETS_DAYS=3 feedgrab https://x.com/i/lists/2002743803959300263
# 输出目录示例：{OUTPUT_DIR}/X/lists_1day/20260304/中推圈AI KOL/
# X_LIST_TWEETS_SUMMARY=false           # 抓取完成后生成汇总表格（MD + CSV），默认关闭

# === Twitter/X 付费 API（TwitterAPI.io）===
# 替代浏览器搜索补充，无推文数量限制，服务器友好，$0.15/千条
# 配置 API Key 后，超过 800 条时自动用 API 替代浏览器搜索
# TWITTERAPI_IO_KEY=                    # API Key，从 https://twitterapi.io 获取
# X_API_PROVIDER=graphql                # graphql(默认,现有流程) | api(全量走付费API,服务器场景)
# X_API_SAVE_DIRECTLY=false             # true=直接保存API数据(快,无图片) / false=API发现+GraphQL下载(推荐)
# X_API_MIN_LIKES=                      # 最低点赞数（留空=不过滤，三项为 OR 关系）
# X_API_MIN_RETWEETS=                   # 最低转发数（留空=不过滤）
# X_API_MIN_VIEWS=                      # 最低阅读量（留空=不过滤）

# === 通用抓取选项 ===
# FORCE_REFETCH=false                 # 强制重新抓取，true=跳过去重检查并覆盖已有文件（用于修复后重新抓取或更新元数据）

# === 小红书 API 模式（推荐，比浏览器快 10x）===
# 需要先安装：pip install xhshow
# 需要先登录：feedgrab login xhs
XHS_API_ENABLED=true                         # API 优先模式（true=API→Pinia→Jina→浏览器四级兜底，false=跳过 API）
# XHS_PINIA_ENABLED=true                     # xhshow 签名失败时自动通过 Pinia Store 注入兜底（默认 true）
# XHS_API_DELAY=1.0                          # API 请求间隔（默认 1s，含随机抖动）
# XHS_FETCH_COMMENTS=false                   # 单篇抓取时是否获取评论全文
# XHS_MAX_COMMENTS=5                         # 评论最大页数（~20条/页）
# XHS_SEARCH_SORT=general                    # 搜索排序: general(综合) / popular(热门) / latest(最新)
# XHS_SEARCH_NOTE_TYPE=all                   # 搜索类型: all(全部) / video(视频) / image(图片)
# XHS_SEARCH_MAX_PAGES=10                    # 搜索最大页数（每页 20 条）
# XHS_SEARCH_SAVE_NOTES=false               # 是否保存单条笔记 .md，默认 false（仅汇总表）
# XHS_SEARCH_MERGE_KEYWORDS=false           # 多关键词搜索时合并为一个汇总表（默认 false=各自独立文件）
# 用法：feedgrab xhs-so "AI Agent"
#       feedgrab xhs-so "claude code,openclaw,养龙虾"            # 多关键词依次搜索
#       feedgrab xhs-so "claude code,openclaw" --merge           # 多关键词合并为一个汇总表

# === 小红书按作者批量抓取 ===
XHS_USER_NOTES_ENABLED=false              # 是否开启按小红书作者批量采集，true 开启 / false 关闭
# XHS_USER_NOTE_MAX_SCROLLS=50           # 作者主页最大滚动次数，默认 50（每次滚动加载约 20 篇）
# XHS_USER_NOTE_DELAY=3                 # 笔记处理间隔秒数，默认 3（浏览器模式，需要更长间隔）
# XHS_USER_NOTES_SINCE=                 # 仅抓取该日期之后的笔记，格式 YYYY-MM-DD，留空=全部

# === 小红书搜索结果批量抓取 ===
XHS_SEARCH_ENABLED=false                  # 是否开启按搜索关键词批量采集，true 开启 / false 关闭
# XHS_SEARCH_MAX_SCROLLS=30             # 搜索页最大滚动次数，默认 30（每次滚动加载约 20 篇）
# XHS_SEARCH_DELAY=3                    # 笔记处理间隔秒数，默认 3

# === 微信公众号文章搜狗搜索 ===
MPWEIXIN_SOGOU_ENABLED=false              # 是否开启搜狗微信文章搜索，true 开启 / false 关闭
# MPWEIXIN_SOGOU_MAX_RESULTS=10          # 每次搜索最大文章数，默认 10，最多 100（搜狗每页10条，最多10页）
# MPWEIXIN_SOGOU_DELAY=3                # 文章处理间隔秒数，默认 3
# 用法：feedgrab mpweixin-so "AI Agent"
# 输出目录：{OUTPUT_DIR}/mpweixin/search_sogou/{keyword}/

# === 微信公众号按账号批量抓取 ===
# 需要先登录 MP 后台：feedgrab login wechat
# MPWEIXIN_ID_SINCE=                      # 仅抓取该日期之后的文章，格式 YYYY-MM-DD（如 2025-01-01），留空=全部
# MPWEIXIN_ID_DELAY=3                     # 文章处理间隔秒数，默认 3
# 用法：feedgrab mpweixin-id "饼干哥哥AGI"
# 输出目录：{OUTPUT_DIR}/mpweixin/account/{公众号名}/

# === 微信公众号专辑批量抓取（mpweixin-zhuanji）===
# MPWEIXIN_ZHUANJI_SINCE=                 # 仅抓取该日期之后的文章，YYYY-MM-DD，留空=全部
# MPWEIXIN_ZHUANJI_DELAY=3               # 文章处理间隔秒数，默认 3
# 用法：feedgrab mpweixin-zhuanji "https://mp.weixin.qq.com/mp/appmsgalbum?__biz=xxx&album_id=xxx"
# 输出目录：{OUTPUT_DIR}/mpweixin/zhuanji/{专辑名}/

# === 微信公众号评论抓取（实验性） ===
# MPWEIXIN_FETCH_COMMENTS=false          # 是否抓取文章评论（默认 false）
# MPWEIXIN_MAX_COMMENTS=100              # 最大评论数（默认 100）
# 注意：appmsg_comment API 需要微信客户端 session（普通浏览器访问返回 "no session"）
# 当前会尝试抓取并优雅降级——无 session 时输出 WARNING 日志，不影响文章抓取
# 单篇 + mpweixin-id + mpweixin-zhuanji 均支持

# === Telegram（可选，用于 TG 频道抓取）===
# TG_API_ID=                           # 从 https://my.telegram.org 获取
# TG_API_HASH=                         # 从 https://my.telegram.org 获取

# === YouTube Data API v3（可选，用于 YouTube 搜索和视频元数据）===
# 免费：10,000 quota 单位/天（搜索 100 单位/次，视频详情 1 单位/次）
# 申请：Google Cloud Console → APIs & Services → YouTube Data API v3 → Create Credentials → API Key
# YOUTUBE_API_KEY=                      # YouTube Data API v3 密钥
# YOUTUBE_REGION=US                     # 搜索地区代码，默认 US
# YOUTUBE_LANG=zh-CN                    # 搜索语言偏好，默认 zh-CN
# YOUTUBE_MAX_RESULTS=10               # 默认搜索结果数，默认 10，最大 50
# YOUTUBE_DOWNLOAD_QUALITY=1080p       # 视频下载分辨率：best/1080p/720p/480p，默认 1080p
# 用法：feedgrab ytb-so "AI Agent"
#       feedgrab ytb-so "教程" --channel @AndrewNg
#       feedgrab ytb-so "机器学习" --order viewCount --after 2025-01-01
#       feedgrab ytb-all https://www.youtube.com/watch?v=xxx    # 一键下载 MD+视频+音频+字幕
#       feedgrab ytb-dlv https://www.youtube.com/watch?v=xxx    # 下载视频 (MP4)
#       feedgrab ytb-dla https://youtu.be/xxx                   # 下载音频 (MP3)，支持短链接
#       feedgrab ytb-dlz https://www.youtube.com/watch?v=xxx    # 下载字幕 (SRT)

# === GitHub（可选，用于 GitHub 仓库 README 抓取）===
# 无 token 时：60 次/小时（按 IP 限流），有 token 时：5,000 次/小时
# 申请：GitHub Settings → Developer Settings → Personal Access Tokens → Generate new token
# 权限：public 仓库无需任何权限，private 仓库需 repo 权限
# GITHUB_TOKEN=                          # GitHub personal access token
# 用法：feedgrab https://github.com/owner/repo
#       feedgrab https://github.com/owner/repo/blob/main/README.md
# 输出目录：{OUTPUT_DIR}/GitHub/

# === 飞书 / Lark ===
# Tier 0: Open API（最快最可靠，需要飞书开放平台凭据）
# 申请：https://open.feishu.cn/app → 创建自建应用 → 凭证与基础信息
# 权限：应用后台 → 权限管理 → 开通 docx:document:readonly + wiki:wiki:readonly
# 还需要将文档/知识库授权给应用（文档右上角「...」→ 更多 → 添加文档应用）
# FEISHU_APP_ID=                          # 飞书开放平台 App ID
# FEISHU_APP_SECRET=                      # 飞书开放平台 App Secret
#
# Tier 1: 浏览器登录态（不配置 API 时自动使用）
# 登录：feedgrab login feishu → 浏览器手动登录 → 保存 session
#
# 单篇用法：feedgrab https://xxx.feishu.cn/wiki/ABC123
#           feedgrab https://xxx.feishu.cn/docx/ABC123
# 批量用法：feedgrab feishu-wiki https://xxx.feishu.cn/wiki/ABC123
#
# FEISHU_WIKI_BATCH_ENABLED=false         # 知识库批量抓取开关（feishu-wiki 命令自动启用）
# FEISHU_WIKI_DELAY=1.0                   # 批量抓取间隔秒数
# FEISHU_WIKI_SINCE=                      # 仅抓取此日期后修改的文档（YYYY-MM-DD）
# FEISHU_DOWNLOAD_IMAGES=false            # 是否下载图片到本地（保存到 attachments/ 子目录，Obsidian 兼容）
# FEISHU_CUSTOM_DOMAINS=                  # 私有化部署域名（逗号分隔，如 xfchat.iflytek.com,feishu.mycompany.cn）
# FEISHU_PAGE_LOAD_TIMEOUT=5000          # Playwright 页面元素等待超时（毫秒），默认 5000，网络慢可适当增大
# FEISHU_CDP_ENABLED=false               # CDP 直连：复用已打开的 Chrome 抓取飞书（需 Chrome --remote-debugging-port=9222 + 飞书已登录）
# 输出目录：{OUTPUT_DIR}/Feishu/

# === 金山文档 / KDocs (WPS) ===
# Tier 0: Playwright ProseMirror DOM 提取（滚动加载全量内容 + 代码块 + 图片）
# 登录：feedgrab login kdocs → 浏览器手动登录 → 保存 session
# 单篇用法：feedgrab https://www.kdocs.cn/l/xxxxx
#
# KDOCS_CDP_ENABLED=true                  # CDP 直连：复用已打开的 Chrome 抓取需登录的金山文档（默认开启，Chrome 未运行时自动降级）（需 Chrome --remote-debugging-port=9222 + 金山文档已登录）
# KDOCS_PAGE_LOAD_TIMEOUT=10000          # Playwright 页面元素等待超时（毫秒），默认 10000
# KDOCS_DOWNLOAD_IMAGES=false            # 是否下载图片到本地（保存到 attachments/ 子目录，Obsidian 兼容）
# 输出目录：{OUTPUT_DIR}/KDocs/

# === 有道云笔记 / Youdao Note ===
# Tier 0: JSON API 直接获取（无需登录，零依赖）
# Tier 1: Playwright iframe DOM 提取（API 失败时兜底）
# Tier 2: Jina Reader（最终兜底）
# 单篇用法：feedgrab https://share.note.youdao.com/ynoteshare/index.html?id=xxx
#
# YOUDAO_DOWNLOAD_IMAGES=false            # 是否下载图片到本地（保存到 attachments/ 子目录，Obsidian 兼容）
# 输出目录：{OUTPUT_DIR}/NoteYouDao/

# === 知乎 / Zhihu ===
# Tier 0: API v4 + Cookie（纯 HTTP，需 z_c0 Cookie）
# Tier 1: Playwright + __INITIAL_STATE__ 提取（结构化数据完整）
# Tier 2: Jina Reader（最终兜底）
# 登录：feedgrab login zhihu → 浏览器手动登录 → 保存 session
# 单篇用法：feedgrab https://www.zhihu.com/question/{qid}/answer/{aid}
#           feedgrab https://zhuanlan.zhihu.com/p/{pid}
# 搜索用法：feedgrab zhihu-so "关键词" --limit 20 --sort hot
#
# ZHIHU_CDP_ENABLED=false                 # CDP 直连：复用已打开的 Chrome 抓取知乎
# ZHIHU_PAGE_LOAD_TIMEOUT=10000           # Playwright 页面元素等待超时（毫秒）
# ZHIHU_DOWNLOAD_IMAGES=false             # 是否下载图片到本地
# ZHIHU_SEARCH_DAYS=30                    # 搜索最近 N 天的内容
# ZHIHU_SEARCH_LIMIT=50                   # 搜索最大结果数
# ZHIHU_SEARCH_SAVE_ANSWERS=false         # 搜索时是否保存每篇答案 .md
# ZHIHU_SEARCH_DELAY=2.0                  # 搜索请求间隔（秒）
# 输出目录：{OUTPUT_DIR}/Zhihu/

# === 媒体文件本地化（可选）===
# 开启后图片/视频下载到 attachments/{item_id}/ 子目录，Markdown 中使用相对路径
# X_DOWNLOAD_MEDIA=false                  # Twitter 图片/视频下载到本地
# XHS_DOWNLOAD_MEDIA=false                # 小红书图片下载到本地
