# === Telegram (optional, for TG channel fetching) ===
TG_API_ID=
TG_API_HASH=

# === Groq Whisper (optional, for video/audio transcription) ===
# Free API key: https://console.groq.com/keys
GROQ_API_KEY=

# === Gemini (optional, for AI-powered analysis) ===
GEMINI_API_KEY=

# === X/Twitter GraphQL (optional, for deep tweet/thread fetching) ===
# Cookie auth: set these to skip browser login for GraphQL API
X_AUTH_TOKEN=
X_CT0=
# GraphQL controls
X_GRAPHQL_ENABLED=true
X_THREAD_MAX_PAGES=20
X_REQUEST_DELAY=1.5

# === Output ===
OUTPUT_DIR=./output
INBOX_FILE=./unified_inbox.json
