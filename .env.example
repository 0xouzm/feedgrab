# === 输出配置 ===
OUTPUT_DIR=./output
INBOX_FILE=./unified_inbox.json
# OBSIDIAN_VAULT=

# === 认证数据目录（cookie/session 统一存放）===
# 相对路径基于项目根目录，也支持绝对路径
# FEEDGRAB_DATA_DIR=sessions

# === Twitter/X ===
# Cookie（推荐用 feedgrab login twitter 自动获取）
# 或手动填写，优先级高于 cookie 文件
# X_AUTH_TOKEN=
# X_CT0=

# GraphQL 控制
X_GRAPHQL_ENABLED=true
X_THREAD_MAX_PAGES=20
X_REQUEST_DELAY=1.5

# 评论采集开关
X_FETCH_AUTHOR_REPLIES=false
X_FETCH_ALL_COMMENTS=false
# X_MAX_COMMENTS=50

# 书签批量抓取
X_BOOKMARKS_ENABLED=false
# X_BOOKMARK_MAX_PAGES=50
# X_BOOKMARK_DELAY=2.0

# === Telegram（可选，用于 TG 频道抓取）===
# TG_API_ID=
# TG_API_HASH=

# === AI 服务（可选）===
# Groq Whisper（视频/音频转录）: https://console.groq.com/keys
# GROQ_API_KEY=
# Gemini（AI 分析）
# GEMINI_API_KEY=
